# Local development needs NONE of these — it uses a local SQLite file
# (fixit.db) and saves uploads to the ./uploads folder.
#
# For production (Vercel) set these as Environment Variables:

# A long random string used to sign login cookies.
JWT_SECRET=change-me-to-a-long-random-string

# Turso (libSQL) database — create one at https://turso.tech
DATABASE_URL=libsql://your-database-name.turso.io
DATABASE_AUTH_TOKEN=your-turso-auth-token

# BLOB_READ_WRITE_TOKEN is added automatically by Vercel when you
# connect a Blob store to the project (Storage tab). No need to set it by hand.
# BLOB_READ_WRITE_TOKEN=
